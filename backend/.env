# Application
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
LOG_LEVEL=debug

# CORS
# Comma-separated list of allowed origins, e.g. http://localhost:5173,https://app.bazar-trace.com
CORS_ORIGIN=http://localhost:5173

# Authentication
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=10

# Oracle Database
# Set to true when you have a reachable Oracle database for local development.
ORACLE_ENABLED=true
# Use a Thin-mode connect string (host:port/service_name) so you
# don't need to install the Oracle Instant Client.
ORACLE_USER=bazar_user
ORACLE_PASSWORD=bazar_pass
ORACLE_CONNECT_STRING=localhost:1523/XEPDB1
# ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# Oracle Connection Pool
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_TIMEOUT=60


# Seed Admin (used only by `npm run db:seed:admin`)
# Defaults are applied if these are unset.
SEED_ADMIN_EMAIL=admin@bazar-trace.local
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Bazar Admin
